# Database (same Postgres instance as openvaia, different schema)
POSTGRES_HOST=localhost
POSTGRES_PORT=5445
POSTGRES_USER=inotives
POSTGRES_PASSWORD=changeme
POSTGRES_DB=inotives
TRADING_SCHEMA=trading_platform

# dbmate connection string (must match the above)
DATABASE_URL=postgresql://inotives:changeme@localhost:5445/inotives?sslmode=disable

# Exchange (default venue — pairs and accounts are configured in DB)
DEFAULT_EXCHANGE=cryptocom
CRYPTOCOM_API_KEY=
CRYPTOCOM_API_SECRET=
TRADING_MODE=paper

# Poller intervals (seconds)
PUBLIC_POLLER_INTERVAL=60
PRIVATE_POLLER_INTERVAL=60
TA_POLLER_INTERVAL=60
TA_DAILY_HOUR=2

# Archival
ARCHIVE_DIR=./archive
OHLCV_1M_RETENTION_DAYS=30
